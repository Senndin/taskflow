# Copy this file to .env and fill in your values
# cp .env.example .env

# Django
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database
# Option 1 — SQLite (no Docker needed):
# DATABASE_URL=sqlite:///db.sqlite3

# Option 2 — PostgreSQL via Docker (docker-compose up -d db):
DATABASE_URL=postgresql://taskflow:taskflow@db:5432/taskflow

# Email (only needed in production)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your@email.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@taskflow.app
